<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup/transfer rules.
  Backs up ONLY the local alerts database — no secrets, no account, no network.
  cloud-backup    = restore on reinstall via the user's own Google Drive backup.
  device-transfer = direct phone-to-phone copy during new-device setup.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="polyalerts.db" />
        <include domain="database" path="polyalerts.db-wal" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="polyalerts.db" />
        <include domain="database" path="polyalerts.db-wal" />
    </device-transfer>
</data-extraction-rules>
